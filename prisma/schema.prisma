generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  platform_owner
  workspace_owner
  manager
  patient
  provider
}

enum WorkspaceType {
  family
  clinical
  assisted_living
  home_health
  specialty
}

enum MedStatus {
  active
  on_hold
  discontinued
  archived
}

enum RRStatus {
  pending
  submitted
  at_prescriber
  at_pharmacy
  ready
  picked_up
  denied
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  approve
  deny
  upload
  invite
}

model User {
  id            String    @id @default(cuid())
  supabase_id   String    @unique
  email         String    @unique
  name          String
  role          Role      @default(patient)
  initials      String?
  color         String?
  status        String    @default("active")
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  workspace_members WorkspaceMember[]
  audit_logs        AuditLog[]
  sent_messages     Message[]         @relation("SentMessages")
  received_messages Message[]         @relation("ReceivedMessages")
  notifications     Notification[]
  refill_requests   RefillRequest[]   @relation("RequestedBy")

  @@map("users")
}

model Workspace {
  id          String        @id @default(cuid())
  name        String
  type        WorkspaceType @default(family)
  description String?
  timezone    String        @default("America/New_York")
  status      String        @default("active")
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  members        WorkspaceMember[]
  patients        Patient[]
  medications     Medication[]
  refill_requests RefillRequest[]
  messages        Message[]
  notifications   Notification[]
  audit_logs      AuditLog[]

  @@map("workspaces")
}

model WorkspaceMember {
  id           String    @id @default(cuid())
  workspace_id String
  user_id      String
  role         Role      @default(manager)
  joined_at    DateTime  @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id])
  @@map("workspace_members")
}

model Patient {
  id              String    @id @default(cuid())
  workspace_id    String
  name            String
  dob             String?
  relationship    String?
  allergies       String    @default("None known")
  emergency_name  String?
  emergency_phone String?
  notes           String?
  initials        String?
  color           String    @default("#0E4F54")
  status          String    @default("active")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  workspace       Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  medications     Medication[]
  refill_requests RefillRequest[]
  symptom_logs    SymptomLog[]
  adherence_logs  AdherenceLog[]
  documents       Document[]
  notifications   Notification[]

  @@map("patients")
}

model Provider {
  id           String  @id @default(cuid())
  npi          String? @unique
  name         String
  specialty    String?
  address      String?
  city         String?
  state        String?
  zip          String?
  phone        String?
  fax          String?
  email        String?
  source       String  @default("nppes")
  created_at   DateTime @default(now())

  medications  Medication[]

  @@map("providers")
}

model Pharmacy {
  id         String   @id @default(cuid())
  npi        String?
  name       String
  address    String?
  city       String?
  state      String?
  zip        String?
  phone      String?
  chain      String?
  source     String   @default("nppes")
  created_at DateTime @default(now())

  medications Medication[]

  @@map("pharmacies")
}

model Medication {
  id               String    @id @default(cuid())
  workspace_id     String
  patient_id       String
  provider_id      String?
  pharmacy_id      String?
  name             String
  generic          String?
  brand            String?
  dosage           String?
  actual_dose      String?
  form             String    @default("Tablet")
  route            String?
  frequency        String?
  instructions     String?
  purpose          String?
  status           MedStatus @default(active)
  quantity         Int       @default(30)
  days_supply      Int       @default(30)
  refills          Int       @default(0)
  last_fill        String?
  next_fill        String?
  rxcui            String?
  notes            String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  workspace       Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  patient         Patient         @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  provider        Provider?       @relation(fields: [provider_id], references: [id])
  pharmacy        Pharmacy?       @relation(fields: [pharmacy_id], references: [id])
  refill_requests    RefillRequest[]     @relation("MedicationRefills")
  symptom_logs       SymptomLog[]
  adherence_logs     AdherenceLog[]
  medication_history MedicationHistory[]

  @@map("medications")
}

model MedicationHistory {
  id            String   @id @default(cuid())
  medication_id String
  field         String
  from_value    String?
  to_value      String?
  changed_by    String?
  changed_at    DateTime @default(now())

  medication Medication @relation(fields: [medication_id], references: [id], onDelete: Cascade)

  @@map("medication_history")
}

model RefillRequest {
  id            String   @id @default(cuid())
  workspace_id  String
  patient_id    String
  medication_id String?
  requested_by  String?
  status        RRStatus @default(pending)
  method        String   @default("electronic")
  notes         String?
  status_history Json    @default("[]")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  workspace  Workspace   @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  patient    Patient     @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  medication Medication? @relation("MedicationRefills", fields: [medication_id], references: [id])
  requester  User?       @relation("RequestedBy", fields: [requested_by], references: [id])

  @@map("refill_requests")
}

model Notification {
  id           String   @id @default(cuid())
  workspace_id String
  patient_id   String?
  user_id      String?
  type         String
  title        String
  message      String
  status       String   @default("unread")
  color        String   @default("blue")
  link         String?
  created_at   DateTime @default(now())

  workspace Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  patient   Patient?   @relation(fields: [patient_id], references: [id])
  user      User?      @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model Message {
  id           String   @id @default(cuid())
  workspace_id String
  sender_id    String
  recipient_id String?
  subject      String?
  body         String
  status       String   @default("unread")
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  sender    User      @relation("SentMessages", fields: [sender_id], references: [id])
  recipient User?     @relation("ReceivedMessages", fields: [recipient_id], references: [id])

  @@map("messages")
}

model AuditLog {
  id           String      @id @default(cuid())
  workspace_id String?
  user_id      String?
  user_name    String?
  action       AuditAction
  entity_type  String
  entity_name  String?
  field        String?
  from_value   String?
  to_value     String?
  ip_address   String?
  created_at   DateTime    @default(now())

  workspace Workspace? @relation(fields: [workspace_id], references: [id])
  user      User?      @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model SymptomLog {
  id            String   @id @default(cuid())
  patient_id    String
  medication_id String?
  symptom       String
  severity      Int      @default(5)
  notes         String?
  logged_at     DateTime @default(now())

  patient    Patient     @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  medication Medication? @relation(fields: [medication_id], references: [id])

  @@map("symptom_logs")
}

model AdherenceLog {
  id            String   @id @default(cuid())
  patient_id    String
  medication_id String
  status        String
  scheduled_at  DateTime
  logged_at     DateTime @default(now())
  notes         String?

  patient    Patient    @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medication_id], references: [id], onDelete: Cascade)

  @@map("adherence_logs")
}

model Document {
  id         String   @id @default(cuid())
  patient_id String
  name       String
  type       String?
  url        String
  size       Int?
  uploaded_by String?
  created_at DateTime @default(now())

  patient Patient @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@map("documents")
}

model FeatureFlag {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?
  enabled     Boolean @default(false)
  env         String  @default("production")
  updated_at  DateTime @updatedAt

  @@map("feature_flags")
}

model SystemSetting {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt

  @@map("system_settings")
}
